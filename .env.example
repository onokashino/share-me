# ── share·me — self-host configuration ──────────────────────────────────────
# Copy to `.env` and adjust. `docker compose` reads it automatically.
# Everything has a sensible default — `docker compose up` works with no .env.

# Public origin the app is served from (Traefik entrypoint). Required by the API.
# HTTP / IP mode: http://localhost (or http://<server-ip>).
# HTTPS mode:     https://<your-domain>.
PUBLIC_BASE_URL=http://localhost

# Host port to publish the Traefik HTTP entrypoint on.
HTTP_PORT=80

# ── Domain + HTTPS (optional) ───────────────────────────────────────────────
# DOMAIN empty  → plain HTTP; reach the server by its IP (or http://localhost).
# DOMAIN set    → automatic Let's Encrypt HTTPS on :443, with :80 redirecting to
#                 it. First point the domain's A/AAAA record at this server, set
#                 ACME_EMAIL, and set PUBLIC_BASE_URL above to https://<domain>.
DOMAIN=
ACME_EMAIL=
# Host port for the HTTPS entrypoint (used only when DOMAIN is set).
HTTPS_PORT=443

# Per-IP API rate limit (requests/second).
RATE_LIMIT_PER_SEC=50

# Max ciphertext size per drop, in bytes (files and text). Default 5 GiB.
# Set to 0 for no limit.
MAX_FILE_SIZE=5368709120

# Optional .onion mirror shown as a Tor chip in the topnav (build-time, web).
# Tor support is groundwork-only for now — leave empty to hide the chip.
NEXT_PUBLIC_TOR_URL=

# Source repository for the GitHub link (footer + topbar). Defaults to the
# canonical repo in code; set this only if you publish a modified fork (AGPL §13).
# Build-time (web).
NEXT_PUBLIC_SOURCE_URL=

# ── S3 / MinIO (only with docker-compose.s3.yml) ────────────────────────────
S3_BUCKET=share-me
S3_REGION=us-east-1
# REQUIRED for the S3 stack — set strong, unique values. The compose S3 override
# refuses to start if these are empty (no usable defaults are shipped).
S3_ACCESS_KEY=
S3_SECRET_KEY=
# MinIO admin console is published on loopback (127.0.0.1) only.
MINIO_CONSOLE_PORT=9001
